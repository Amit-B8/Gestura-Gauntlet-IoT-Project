# Gestura Gauntlet — Backend Environment Variables
# Copy this to .env and fill in your values.

PORT=3001

# Port for the embedded MQTT broker (Pico connects here)
MQTT_BROKER_PORT=1883

# Local IP addresses of your Kasa devices
# Find these in the Kasa mobile app under Device Info
PLUG_IP=192.168.1.XXX
BULB_IP=192.168.1.XXX
KASA_TIMEOUT_MS=4000

# Live X-axis to Kasa bulb brightness control
# Default maps accelerometer x=-1 to 0% and x=+1 to 100% while mode is active.
# If you want gyro rate instead of tilt, set GYRO_BULB_AXIS=gx and tune min/max.
GYRO_BULB_CONTROL_ENABLED=true
GYRO_BULB_CONTROL_MODE=active
GYRO_BULB_AXIS=x
GYRO_BULB_AXIS_MIN=-1
GYRO_BULB_AXIS_MAX=1
GYRO_BULB_THROTTLE_MS=125
GYRO_BULB_MIN_DELTA=1
GYRO_BULB_SMOOTHING=0.6
GYRO_BULB_TRANSITION_MS=80
GYRO_BULB_POWER_OFF_AT_ZERO=true

# Passive mode bulb behavior
# Red = still, Green = moving
PASSIVE_MOTION_WINDOW_SIZE=8
PASSIVE_MOTION_MOVING_THRESHOLD=0.08
PASSIVE_MOTION_STILL_THRESHOLD=0.03
PASSIVE_MOTION_BRIGHTNESS=100
PASSIVE_MOTION_TRANSITION_MS=0
PASSIVE_DEBUG_LOG_ENABLED=true
PASSIVE_DEBUG_LOG_INTERVAL_MS=500
PASSIVE_SENSOR_STALE_MS=2000
